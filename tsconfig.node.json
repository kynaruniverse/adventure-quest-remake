{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "skipLibCheck": true,

    "noEmit": true,

    "strict": true,
    "isolatedModules": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "types": ["node"]
  },

  "include": ["vite.config.ts"]
}